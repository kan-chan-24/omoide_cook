<!--コピーライト-->
<div class="px-10 md:px-20 lg:px-40">
  <div class="pb-10">
    <p class="text-[#BC6C43] text-xs md:text-sm tracking-widest mb-2 md:mb-4 font-medium">あの味、あの場所、あのひと</p>
    <h1 class="text-[#2A1A0A] text-3xl md:text-5xl font-bold leading-tight mb-2 md:mb-4 tracking-tight">思い出の味を、<br>言葉で残す場所。</h1>
    <p class="text-[#5C5346] text-sm md:text-base md:leading-normal tracking-tight space-y-2">レシピよりも、エピソードを大切に。<br>料理にまつわる記憶と、そこにいた人たちを記録しよう</p>
  </div>
  <!-- 投稿一覧 -->
  <div class="pt-5 border-t border-gray-500/25">
    <!-- カードの配置 -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 pb-3 ">
      <% @posts.each do |post| %>
      <!--カードのスタイル-->
      <div class="bg-[#FAF6EE] border border-[#EBE3D3] shadow-sm overflow-hidden flex flex-col">
        <!-- カード上部：画像部分 -->
        <div class="relative aspect-video overflow-hidden">
          <%= image_tag post.image, class: "brightness-95 w-full h-full object-cover" %>
          <span class="absolute bottom-3 left-4 text-white font-serif-sub text-sm drop-shadow-xl">
            <%= post.when %>
          </span>
        </div>
        <!--カード下部：テキスト部分-->
        <div class="px-4 py-3 flex-1 flex flex-col justify-between">
          <!--タイトルと本文  -->
          <div class="py-2">
            <h2 class="text-[#2A1A0A] text-lg lg:text-xl font-bold tracking-wide"><%= post.title %></h2>
            <p class="text-[#5C5346] text-xs md:text-sm lg:text-base tracking-wide leading-loose line-clamp-3"><%= post.episode %></p>
          </div>
          <!-- ユーザー名 -->
          <div class="border-t border-gray-500/25 pt-4 pb-2 mt-auto">
            <p class="text-[#5C5346] text-base tracking-wide">by <%= post.user.name %></p>
          </div>
        </div>
      </div>
      <% end %>
    </div>
  </div>
</div>