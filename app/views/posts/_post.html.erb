<!-- 投稿内容の表示 -->
<!-- カードのスタイル -->
<%= link_to post_path(post), 
            id: dom_id(post), 
            data: { 
                turbo_frame: "modal_content",
                action: "click->modal#openShow"
            }, 
            class: "bg-[#FAF6EE] border border-[#EBE3D3] shadow-sm overflow-hidden flex flex-col hover:opacity-95 transition-opacity block cursor-pointer" do %>
    <!-- カード上部：画像部分 -->
    <div class="relative aspect-video overflow-hidden">
        <% if post.image.attached? %>
            <!-- cl_image_tag: Cloudinary専用のimgタグ生成ヘルパー -->
            <!-- fetch_format: :autoでHEICなどもブラウザが表示できる形式へ自動変換 -->
            <%= cl_image_tag post.image.key,
              fetch_format: :auto,
              quality: :auto,
              crop: :fill,
              width: 600,
              height: 338,
              class: "brightness-95 w-full h-full object-cover" %>
        <% else %>
          <!-- 料理名の文字数から、1〜3の数字を自動計算する -->
          <% image_index = (post.title.hash % 3).abs + 1 %>
          <% placeholder_filename = "food_sample#{image_index}.jpg" %>
          
          <%= image_tag placeholder_filename, class: "brightness-95 w-full h-full object-cover", alt: post.title %>
        <% end %>
        <span class="absolute bottom-3 left-4 text-white font-serif-sub text-sm drop-shadow-xl">
            <%= post.when %>
        </span>
    </div>

    <!--カード下部：テキスト部分 -->
    <div class="px-4 py-3 flex-1 flex flex-col justify-between">
        <!--タイトルと本文  -->
        <div class="py-2">
            <h2 class="text-[#2A1A0A] text-lg lg:text-xl font-bold tracking-wide"><%= post.title %></h2>
            <p class="text-[#5C5346] text-xs md:text-sm lg:text-base tracking-wide leading-loose line-clamp-3"><%= post.episode %></p>
        </div>
        <!-- ユーザー名 -->
        <div class="border-t border-gray-500/25 pt-4 pb-2 mt-auto">
            <p class="text-[#5C5346] text-base tracking-wide">by <%= post.user.name %></p>
        </div>
    </div>
<% end %>