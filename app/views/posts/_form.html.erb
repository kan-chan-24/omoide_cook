<!-- 投稿フォームのテンプレ -->
<%= form_with model: post, id: "post_form", class: "space-y-6", data: { controller: "post-form", post_form_modal_outlet: "#global-modal", action: "keydown->post-form#preventEnterSubmit" } do |f| %>
    <!-- タブ切り替え部分 -->
    <div class="flex border-b border-[#e1d3c7] mb-6">
        <!-- エピソードタブ -->
        <button type="button"
                data-post-form-target="episodeTab"
                data-action="click->post-form#showEpisode"
                class="w-1/2 py-3 text-center bg-[#80351d] text-white font-medium text-sm flex items-center justify-center gap-1 rounded-t-sm">
            <span class="inline-block w-5 h-5 rounded-full border border-white text-xs flex items-center justify-center">1</span> エピソード
        </button>
        <!-- レシピタブ -->
        <button type="button" 
                data-post-form-target="recipeTab" 
                data-action="click->post-form#showRecipe" 
                class="w-1/2 py-3 text-center text-[#8e7e75] font-medium text-sm flex items-center justify-center gap-1">
            <span class="inline-block w-5 h-5 rounded-full border border-[#8e7e75] text-xs flex items-center justify-center">2</span> レシピ（任意）
        </button>
    </div>

    <!-- ① エピソードタブ コンテンツ -->
    <div data-post-form-target="episodeContent" class="space-y-6">
        <!-- 料理の名前 -->
        <div>
            <div class="flex items-baseline justify-between pr-2 md:pr-5 mb-2">
                <%= f.label :title, "この料理に名前をつけるなら", class: "block text-xs text-[#8e7e75] mb-2 font-medium" %>
                <!-- 料理の名前のエラー表示 -->
                <% if post.errors[:title].any? %>
                    <span class="text-[#dc143c] text-[11px] font-semibold"><%= post.errors[:title].join("、") %></span>
                <% end %>
            </div>
            <%= f.text_field :title,
                placeholder: "例：おばあちゃんの肉じゃが、風邪の日のコンソメスープ",
                class: "w-full p-3 bg-[#f2eae1] border-none text-[#4a3b32] text-sm placeholder-[#b1a296] focus:ring-1 focus:ring-[#80351d] focus:outline-none rounded-sm"  %>
        </div>
        <!-- いつ頃か -->
        <div>
            <div class="flex items-baseline justify-between pr-2 md:pr-5 mb-2">
                <%= f.label :when, "この料理を食べた・食べていたのはいつ頃？", class: "block text-xs text-[#8e7e75] mb-2 font-medium" %>
                <!-- エラー表示 -->
                <% if post.errors[:when].any? %>
                    <span class="text-[#dc143c] text-[11px] font-semibold"><%= post.errors[:when].join("、") %></span>
                <% end %>
            </div>
            <%= f.text_field :when,
                placeholder: "例：子供の頃、新卒一年目の時",
                class: "w-full p-3 bg-[#f2eae1] border-none text-[#4a3b32] text-sm placeholder-[#b1a296] focus:ring-1 focus:ring-[#80351d] focus:outline-none rounded-sm"  %>
        </div>
        <!-- 画像選択 -->
        <div>
            <%= f.label :image, "料理の写真", class: "block text-xs text-[#8e7e75] mb-2 font-medium" %>
            <div class="relative flex items-center justify-center w-full p-4 bg-[#f2eae1] rounded-sm cursor-pointer hover:bg-[#ebdcd0] transition-colors group">
                
                <!-- id, onchange を削除。action と target を追加 -->
                <%= f.file_field :image, 
                    data: { 
                    action: "change->post-form#updateFileName",
                    post_form_target: "fileInput",
                    attached_name: (f.object.image.attached? ? f.object.image.filename.to_s : nil) 
                    }, 
                    class: "absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" %>
                    
                <div class="text-center pointer-events-none">
                    <!-- id を削除。target を追加 -->
                    <span data-post-form-target="fileNameDisplay" class="text-sm text-[#8e7e75] group-hover:text-[#4a3b32] break-all px-4 block">
                        <% if f.object.image.attached? %>
                            <%= f.object.image.filename.to_s %>
                        <% else %>
                            画像を選択する
                        <% end %>
                    </span>
                </div>
            </div>
        </div>
        <!-- エピソード入力欄（全体をdivで囲み、カウンター用のコントローラーを指定します） -->
        <div class="space-y-2" data-controller="episode-counter" data-episode-counter-max-length-value="<%= Post::MAX_EPISODE_LENGTH %>">
            
            <!-- ラベルとインラインエラー表示 -->
            <div class="flex items-baseline justify-between pr-2 md:pr-5 mb-2">
                <%= f.label :episode, "この料理で思い出すこと", class: "block text-xs text-[#8e7e75] mb-2 font-medium"  %>
                <% if post.errors[:episode].any? %>
                    <span class="text-[#dc143c] text-[11px] font-semibold"><%= post.errors[:episode].join("、") %></span>
                <% end %>
            </div>
            
            <!-- 入力欄（文字が入力される「input」イベント時に、JSの「update」関数を動かす設定） -->
            <%= f.text_area :episode, rows: 6, placeholder: "その料理にまつわる思い出を、自由に書いてください。", data: { episode_counter_target: "input", action: "input->episode-counter#update" }, class: "w-full p-4 bg-[#f2eae1] border-none text-[#4a3b32] text-sm leading-relaxed placeholder-[#b1a296] focus:ring-1 focus:ring-[#80351d] focus:outline-none resize-none rounded-sm" %>
            
            <!-- 進捗バー（メーター） -->
            <div class="w-full h-1 bg-gray-200 rounded-full overflow-hidden">
                <div data-episode-counter-target="progressBar" class="h-full bg-[#80351d] transition-all duration-150" style="width: 0%;"></div>
            </div>

            <!-- 文字数カウントの数字表示（右寄せ） -->
            <div class="text-right text-xs text-[#8e7e75]">
                <span data-episode-counter-target="count" class="font-medium">0</span> / <%= Post::MAX_EPISODE_LENGTH %>文字
            </div>
        </div>
    </div>

    <!-- ② レシピ（任意）タブ コンテンツ -->
    <div data-post-form-target="recipeContent" class="space-y-6 hidden">
        <p class="text-xs text-[#a39489]">
            レシピは任意です。覚えていなければスキップしていただいても大丈夫です。
        </p>

        <!-- 食材/材料 -->
        <div>
            <!-- エラー表示 -->
            <div class="flex items-baseline justify-between pr-2 md:pr-5 mb-2">
                <label class="block text-xs text-[#8e7e75] mb-2 font-medium">材料</label>
                <% if post.errors[:ingredients].any? %>
                    <span class="text-[#dc143c] text-[11px] font-semibold"><%= post.errors[:ingredients].join("、") %></span>
                <% end %>
            </div>
            <!-- DBに保存されている材料を1つずつ取り出してループ表示 -->
            <!-- データが空っぽ（新規）の場合は、最低1つの空の入力欄を表示 -->
            <div data-post-form-target="ingredientsContainer" class="space-y-2">
                <% (post.ingredients.presence || [""]).each do |ingredient| %>
                    <div class="ingredient-field flex items-center gap-2">
                        <!-- value 属性に、取り出した一括データ（ingredient）をそのまま流し込む -->
                        <input type="text" 
                               name="post[ingredients][]" 
                               placeholder="例：豚こま肉 200g" 
                               value="<%= ingredient %>" 
                               class="w-full p-3 bg-[#f2eae1] border-none text-[#4a3b32] text-sm placeholder-[#b1a296] focus:ring-1 focus:ring-[#80351d] focus:outline-none rounded-sm">
                        <button type="button" data-action="click->post-form#removeIngredient" class="p-2 text-[#8e7e75] hover:text-[#80351d] bg-transparent border-none cursor-pointer">🗑️</button>
                    </div>
                <% end %>
            </div>
            <button type="button" data-action="click->post-form#addIngredient" class="mt-2 text-xs font-bold text-[#80351d] bg-transparent border-none cursor-pointer hover:underline">+ 材料を追加する</button>
        </div>

        <!-- 作り方セクション -->
        <div>
            <!-- エラー表示 -->
            <div class="flex items-baseline justify-between pr-2 md:pr-5 mb-2">
                <label class="block text-xs text-[#8e7e75] mb-2 font-medium">作り方</label>
                <% if post.errors[:steps].any? %>
                    <span class="text-[#dc143c] text-[11px] font-semibold"><%= post.errors[:steps].join("、") %></span>
                <% end %>
            </div>
            <!-- 材料と同じく、保存されている工程をループ表示 -->
            <!-- each_with_index を使うことで、左側の工程番号（1, 2, 3..）も自動で連動 -->
            <div data-post-form-target="stepsContainer" class="space-y-3">
                <% (post.steps.presence || [""]).each_with_index do |step, index| %>
                    <div class="step-field flex items-start gap-2">
                        <span class="step-number min-w-[20px] pt-3 text-sm font-bold text-[#80351d]"><%= index + 1 %></span>
                        <!-- 💡 【超重要】textarea から value 属性を消し、タグの「間」に <%= step %> を挟み込みました -->
                        <textarea name="post[steps][]" 
                                  rows="2" 
                                  placeholder="例：野菜を一口大に切る" 
                                  class="w-full p-3 bg-[#f2eae1] border-none text-[#4a3b32] text-sm placeholder-[#b1a296] focus:ring-1 focus:ring-[#80351d] focus:outline-none resize-none rounded-sm"><%= step %></textarea>
                        <button type="button" data-action="click->post-form#removeStep" class="p-2 pt-3 text-[#8e7e75] hover:text-[#80351d] bg-transparent border-none cursor-pointer">🗑️</button>
                    </div>
                <% end %>
            </div>
            <button type="button" data-action="click->post-form#addStep" class="mt-2 text-xs font-bold text-[#80351d] bg-transparent border-none cursor-pointer hover:underline">+ 工程を追加する</button>
        </div>
    </div>

    <!-- アクションボタン（次へ / 投稿する） -->
    <div class="flex gap-4 pt-2">
        <button type="button" 
                data-post-form-target="backBtn" 
                data-action="click->post-form#showEpisode" 
                class="w-1/3 py-4 text-center text-sm font-medium text-[#8e7e75] bg-[#ebdcd0] hover:bg-[#dccbc0] transition-colors rounded-sm cursor-pointer border-none hidden">
            ← 戻る
        </button>
        <%= f.submit "次へ →", 
            data: {
                post_form_target: "submitBtn", 
                action: "click->post-form#handleNext" 
            }, 
            class: "flex-1 py-4 text-center text-sm font-medium text-white bg-[#80351d] hover:bg-[#6d2b16] transition-colors rounded-sm cursor-pointer border-none" %>
    </div>
<% end %>