<!-- type と message の2つを、呼び出し側（後述の②③）から受け取って表示する -->
<div data-controller="flash"
     class="pointer-events-auto inline-block w-auto max-w-xs px-4 py-2.5 rounded-lg shadow-md text-xs font-semibold text-left
            transition-all duration-500 ease-out opacity-0 translate-x-4
            <%= type == "alert" ? 'bg-[#fdf0f0] text-[#9c3b3b]' : 'bg-[#eaf6ec] text-[#2f6b2a]' %>">
  <%= message %>
</div>