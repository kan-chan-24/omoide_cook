<header class="bg-[#f7f5ed]/85 backdrop-blur-sm py-4 border-b border-gray-500/25 sticky top-0 z-50">
    <div class="flex justify-between items-center px-10 md:px-20 lg:px-40">
      <!-- 左端：アプリタイトル -->
      <div>
        <%= link_to "あの時食べたアレ", root_path, class: "text-xl md:text-2xl font-bold text-[#2A1A0A] tracking-wide hover:opacity-80 transition" %>
      </div>
      <!-- 右端：投稿ボタン -->
      <div>
        <!-- <%= link_to "+ 書く", root_path, class: "bg-[#8C3B2B] text-white text-sm font-semibold px-3 md:px-5 py-2 rounded shadow-sm hover:bg-[#8f3225] transition" %>  -->
        <%= button_tag "+ 書く", 
        type: "button",
        data: { action: "click->modal#open" },
        class: "bg-[#8C3B2B] text-white text-sm font-semibold px-3 md:px-5 py-2 rounded shadow-sm hover:bg-[#8f3225] transition" %>
      </div>
    </div>
</header>