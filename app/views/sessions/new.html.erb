<div class="max-w-md mx-auto my-12 px-6 py-8 bg-[#FAF6EE] border border-[#EBE3D3] shadow-sm rounded-sm font-serif text-[#3a2d28]">
  
  <!-- ヘッダー部分 -->
  <div class="text-center mb-8">
    <span class="inline-block text-xs border border-[#9b5134] text-[#9b5134] px-3 py-1 font-bold mb-4 transform -rotate-2 origin-center select-none">
      おかえりなさい
    </span>
    <h2 class="text-xl font-bold text-[#2c1d11] tracking-wide">
      ログインする
    </h2>
  </div>

  <!-- 💡 コントローラーで表示した flash.now[:alert] のエラーを表示します -->
  <% if flash[:alert] %>
    <div class="mb-6 p-3 bg-red-50 border border-red-200 text-[#dc143c] text-xs font-semibold rounded-sm">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <!-- ログインフォーム -->
  <!-- 特定のモデル（@user）を保存するわけではないので scope: :session を指定 -->
  <%= form_with scope: :session, url: login_path, class: "space-y-6" do |f| %>
    
    <!-- お名前 -->
    <div>
      <%= f.label :name, "お名前（表示名）", class: "block text-xs font-medium text-[#8e7e75] mb-2" %>
      <%= f.text_field :name,
          placeholder: "例：みつき",
          class: "w-full p-3 bg-[#f2eae1] border-none text-[#4a3b32] text-sm placeholder-[#b1a296] focus:ring-1 focus:ring-[#80351d] focus:outline-none rounded-sm" %>
    </div>

    <!-- パスワード -->
    <div>
      <%= f.label :password, "パスワード", class: "block text-xs font-medium text-[#8e7e75] mb-2" %>
      <%= f.password_field :password,
          placeholder: "••••••••",
          class: "w-full p-3 bg-[#f2eae1] border-none text-[#4a3b32] text-sm placeholder-[#b1a296] focus:ring-1 focus:ring-[#80351d] focus:outline-none rounded-sm" %>
    </div>

    <!-- 送信ボタン -->
    <div class="pt-2">
      <%= f.submit "ログインする", 
          class: "w-full py-4 text-center text-sm font-semibold text-white bg-[#8C3B2B] hover:bg-[#7d3a3d] transition-colors rounded shadow-sm cursor-pointer border-none" %>
    </div>

  <% end %>
</div>